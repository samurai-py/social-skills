{
  "mcpServers": {
    "static-ads": {
      "command": "node",
      "args": ["${STATIC_ADS_MCP_PATH}/server.js"]
    },
    "adsagent": {
      "command": "node",
      "args": ["${ADSAGENT_MCP_PATH}/server.js"],
      "env": {
        "ADSAGENT_API_KEY": "SET_YOUR_KEY_HERE"
      }
    },
    "apify": {
      "command": "npx",
      "args": ["-y", "@apify/actors-mcp-server"],
      "env": {
        "APIFY_TOKEN": "SET_YOUR_TOKEN_HERE"
      }
    }
  }
}
